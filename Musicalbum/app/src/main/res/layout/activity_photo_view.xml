<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerPhotos"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay Info (Top) -->
    <LinearLayout
        android:id="@+id/layoutInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#66000000"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/tvPhotoDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPhotoTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="#66000000"
        android:layout_alignParentBottom="true">

        <ImageView
            android:id="@+id/btnSlideshow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:layout_marginHorizontal="20dp"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="Slideshow" />

        <ImageView
            android:id="@+id/btnFavPhoto"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:layout_marginHorizontal="20dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Yêu thích" />

        <ImageView
            android:id="@+id/btnDeletePhoto"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:layout_marginHorizontal="20dp"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="Xóa" />

    </LinearLayout>

</RelativeLayout>