<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:gravity="center_vertical"
    android:background="@drawable/ripple_card">

    <!-- Checkbox chọn nhiều -->
    <CheckBox
        android:id="@+id/cbSelectSong"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:visibility="gone"
        android:clickable="false"
        android:layout_marginEnd="8dp"
        android:buttonTint="@color/primary"/>

    <!-- Số thứ tự hoặc indicator đang phát -->
    <TextView
        android:id="@+id/tvSongIndex"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:layout_marginEnd="10dp"/>

    <!-- Album Art Thumbnail -->
    <androidx.cardview.widget.CardView
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        android:layout_marginEnd="14dp">

        <ImageView
            android:id="@+id/imgAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="@color/surface_card_light"/>

        <!-- Now Playing Indicator -->
        <ImageView
            android:id="@+id/imgNowPlaying"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/bg_now_playing_overlay"
            android:padding="14dp"
            android:visibility="gone"
            app:tint="@android:color/white"/>

    </androidx.cardview.widget.CardView>

    <!-- Song Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSongTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvSongArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:singleLine="true"/>

    </LinearLayout>

    <!-- Thời lượng -->
    <TextView
        android:id="@+id/tvSongDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:layout_marginEnd="12dp"/>

    <!-- Nút trái tim yêu thích -->
    <ImageView
        android:id="@+id/btnHeartSong"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@android:drawable/btn_star_big_off"
        android:padding="2dp"
        android:background="@drawable/ripple_circle"/>

</LinearLayout>